let curLevel='weak',curPat=0;
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1800);}
function renderPatternTabs(){const st=LS[curLevel];document.getElementById('ptabs').innerHTML=D[curLevel].patterns.map((p,i)=>{const a=i===curPat;return`<button class="ptb" onclick="selectPat(${i})" style="border-color:${st.pc[i]};background:${a?st.pb[i]:'#fff'};color:${a?st.pc[i]:'#666'}">${p.label}</button>`;}).join('');}
function renderPattern(){
  const st=LS[curLevel],p=D[curLevel].patterns[curPat],col=st.pc[curPat],bg=st.pb[curPat];
  const sLines=p.s.map(x=>'– '+x).join('\n'),dLines=p.d.map(x=>'– '+x).join('\n'),full=sLines+'\n\n'+dLines;
  const sPts=p.s.map(x=>`<div class="pt s" data-text="– ${x}">– ${x}</div>`).join('');
  const dPts=p.d.map(x=>`<div class="pt d" data-text="– ${x}">– ${x}</div>`).join('');
  const area=document.getElementById('area');
  area.innerHTML=`<div class="card" style="border-color:${col};background:${bg};"><span class="pat-label" style="background:${col};">${p.label}</span><div class="sec-label">⭐ Strengths</div><div class="pt-hint">اضغط على أي جملة لنسخها</div>${sPts}<button class="sec-copy" id="btn-s">⧉ Copy strengths</button><div class="divider"></div><div class="sec-label">↑ Areas for development</div><div class="pt-hint">اضغط على أي جملة لنسخها</div>${dPts}<button class="sec-copy" id="btn-d">⧉ Copy areas for development</button><button class="full-copy" id="btn-f">⎘ Copy full comment block</button></div>`;
  area.querySelectorAll('.pt').forEach(el=>{el.addEventListener('click',()=>{navigator.clipboard.writeText(el.dataset.text).then(()=>showToast('Copied!'));});});
  document.getElementById('btn-s').addEventListener('click',()=>{navigator.clipboard.writeText(sLines).then(()=>showToast('Strengths copied!'));});
  document.getElementById('btn-d').addEventListener('click',()=>{navigator.clipboard.writeText(dLines).then(()=>showToast('Areas for development copied!'));});
  document.getElementById('btn-f').addEventListener('click',()=>{navigator.clipboard.writeText(full).then(()=>showToast('Full block copied!'));});
}
function selectPat(i){curPat=i;renderPatternTabs();renderPattern();}
function showLevel(level){curLevel=level;curPat=0;document.querySelectorAll('.ltb').forEach(b=>b.classList.remove('active'));const map={weak:'wk',acceptable:'ac',good:'gd',vgood:'vg',outstanding:'os'};document.querySelector('.ltb.'+map[level]).classList.add('active');document.getElementById('level-wrap').className='level-frame '+LS[level].frame;renderPatternTabs();renderPattern();}
showLevel('weak');
</script>
